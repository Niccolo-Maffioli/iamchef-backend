# Root .gitignore for templateProgetto
# Java / Maven
target/
**/target/
*.class
*.jar
*.war
*.ear

# Maven wrapper - include wrapper jar if you want to commit it, otherwise ignore
.mvn/wrapper/maven-wrapper.jar

# Spring Boot
logs/
*.log

# IDEs and editors
.idea/
*.iml
/.classpath
/.project
.settings/
.vscode/
/.metadata/

# OS files
.DS_Store
Thumbs.db

# Node / frontend
**/node_modules/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# pnpm
pnpm-debug.log*

# Vite / build outputs
dist/
frontend/dist/
build/
.vite/
.cache/

# Static analysis / coverage
coverage/
*.lcov

# Environment
.env
.env.*

# Logs and runtime files
hs_err_pid*
*.pid

# Generated files
generated/

# Misc
*.log
